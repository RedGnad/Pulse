# ─── AI Provider Configuration ───────────────────────────────────────────────
# Supports: Anthropic (default), OpenAI, Ollama, LM Studio, Groq, Together, etc.
# See README.md for provider-specific examples.

AI_PROVIDER=anthropic
AI_MODEL=claude-haiku-4-5-20251001
AI_API_KEY=your_api_key_here

# Optional: for OpenAI-compatible providers (Ollama, LM Studio, Groq, etc.)
# AI_PROVIDER=openai
# AI_BASE_URL=http://localhost:11434/v1
# AI_MODEL=llama3

# AI Mock Mode — set to "true" to skip all AI calls during development.
AI_MOCK=true

# ─── Pulse EVM Rollup (MiniEVM) ─────────────────────────────────────────────
# Each developer deploys their own contracts — addresses come from deployment.
PULSE_ORACLE_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
PULSE_EVM_RPC=http://localhost:8545
PULSE_EVM_CHAIN_ID=2150269405855764
NEXT_PUBLIC_PULSE_REST=http://localhost:1317
NEXT_PUBLIC_PULSE_RPC=http://localhost:26657
NEXT_PUBLIC_PULSE_JSON_RPC=http://localhost:8545
NEXT_PUBLIC_PULSE_EVM_CHAIN_ID=2150269405855764
NEXT_PUBLIC_PULSE_CHAIN_ID=initia-pulse-1

# Contract addresses (set after deploying with forge create)
NEXT_PUBLIC_PULSE_ORACLE_ADDRESS=
NEXT_PUBLIC_PULSE_GOV_ADDRESS=
